# Copy to /etc/rizzoma/production.env as root:root mode 0600.
# Populate secret values locally on the VPS. Never commit them.
NODE_ENV=production
HOST=127.0.0.1
FEAT_ALL=1
FEAT_RIZZOMA_PARITY_RENDER=1
APP_URL=https://138-201-62-161.nip.io
APP_BASE_URL=https://138-201-62-161.nip.io
CLIENT_URL=https://138-201-62-161.nip.io
ALLOWED_ORIGINS=https://138-201-62-161.nip.io,https://dev.138-201-62-161.nip.io
COUCHDB_URL=REPLACE_WITH_CURRENT_PRODUCTION_URL
COUCHDB_DB=project_rizzoma
REDIS_URL=redis://127.0.0.1:6379
UPLOADS_STORAGE=local
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
SESSION_SECRET=REPLACE_WITH_A_RANDOM_SECRET
# Leave empty for the July 2026 incident cutover. The internet-exposed Redis
# sessions were intentionally invalidated and the known fallback must not be
# accepted. For future planned rotations only, this may temporarily hold the
# immediately preceding strong secret.
SESSION_SECRET_PREVIOUS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
EMAIL_FROM=
LOG_TO_FILE=0
