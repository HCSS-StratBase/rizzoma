# Development logs
*.log

# Hard Gap #24 (2026-04-13) — local scratch / dev junk that kept showing up
# in git status. Documented in docs/HANDOFF.md / CLAUDE_SESSION.md as the
# four skip-listed items.
tmp/
scripts/__pycache__/
gpu_hog_report.bat
tana-tools.json
# Local rizzoma backup bundles (the dated copies live on GDrive — see
# docs/HANDOFF.md and Rizzoma-backup/README.md). The legacy `rizzoma.bundle`
# entry above already covers the unsuffixed pointer; this catches the
# dated variants too.
rizzoma-*.bundle

# Winston rotating file logs (runtime audit trail — see
# src/server/lib/logger.ts). Never commit .log content.
logs/

# Capacitor native project build artifacts (2026-04-14). The native
# project trees THEMSELVES are committed (android/, ios/) because
# Capacitor does not regenerate them from scratch on sync — devs need
# the Xcode/Gradle configuration to stay reproducible. Build outputs
# and local IDE state are ignored.
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
ios/App/Pods/
ios/App/build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
DerivedData/

# Built APK output (reproducible from source — do not commit).
dist/apk/
.claude/
